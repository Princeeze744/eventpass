generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  phone        String?
  role         String   @default("planner")
  isStaff      Boolean  @default(false)
  staffLevel   String   @default("none")
  staffSince   DateTime?
  invitedBy    String?
  suspended    Boolean  @default(false)
  createdAt    DateTime @default(now())
  events       Event[]
}

model Event {
  id        String @id @default(cuid())
  slug      String @unique
  ownerId   String
  owner     User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  title      String
  hostName   String  @default("")
  tagline    String  @default("A Celebration")
  eventDate  String
  eventTime  String  @default("12:00 PM")
  venue      String
  address    String  @default("")

  logoUrl     String?
  accentColor String  @default("#d4af37")

  deadline     DateTime?
  capacity     Int?
  approvalMode String    @default("manual")

  adminKey String
  usherKey String

  approval      String    @default("pending")
  approvedAt    DateTime?
  approvedBy    String?
  reviewNote    String?
  paymentStatus String    @default("unpaid")
  paymentAmount Int?
  paymentNote   String?

  story        String?
  dressCode    String?
  colours      String?
  hotels       String?
  restaurants  String?
  funSpots     String?
  ceremonyName String?
  ceremonyMap  String?
  receptionMap String?
  livestream   String?
  programNote  String?
  menuNote     String?
  giftNote     String?
  coverImage   String?
  gallery      String?
  hashtag      String?
  bankDetails  String?

  createdAt DateTime @default(now())
  deletedAt DateTime?
  guests    Guest[]
  tables    SeatTable[]
}

model SeatTable {
  id       String @id @default(cuid())
  eventId  String
  event    Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  name     String
  section  String @default("Main")
  capacity Int    @default(10)
  note     String @default("")
  position Int    @default(0)

  createdAt DateTime @default(now())

  @@index([eventId])
}

model Guest {
  id      String @id @default(cuid())
  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  passId   String  @unique
  name     String
  phone    String?
  category String  @default("Guest")
  tier     String  @default("Guest")

  partySize Int @default(1)
  partyUsed Int @default(0)

  section String @default("")
  wristband String @default("")
  table   String @default("TBA")
  seat    String @default("")

  status          String    @default("pending")
  rsvpAnswer      String    @default("yes")
  declinedAt      DateTime?
  checkedInOnline Boolean   @default(false)
  checkedIn       Boolean   @default(false)
  checkedInAt     DateTime?
  souvenirTaken   Boolean   @default(false)

  createdAt DateTime @default(now())
  deletedAt DateTime?

  @@unique([eventId, phone])
  @@index([eventId])
}
